{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "PMOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_user",
    "core_problem",
    "p0_features",
    "p1_features",
    "riskiest_assumptions",
    "recommended_next_step"
  ],
  "properties": {
    "target_user": { "type": "string" },
    "core_problem": { "type": "string" },
    "p0_features": { "type": "array", "items": { "type": "string" } },
    "p1_features": { "type": "array", "items": { "type": "string" } },
    "riskiest_assumptions": { "type": "array", "items": { "type": "string" } },
    "recommended_next_step": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "ShipPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "final_verdict",
    "shippable_definition",
    "ship_blockers_ordered",
    "post_ship_backlog",
    "killed",
    "one_week_ship_plan",
    "risks_on_ship_day"
  ],
  "properties": {
    "final_verdict": { "type": "string" },
    "shippable_definition": { "type": "string" },
    "ship_blockers_ordered": { "type": "array", "items": { "type": "string" } },
    "post_ship_backlog": { "type": "array", "items": { "type": "string" } },
    "killed": { "type": "array", "items": { "type": "string" } },
    "one_week_ship_plan": { "type": "array", "items": { "type": "string" } },
    "risks_on_ship_day": { "type": "array", "items": { "type": "string" } }
  }
}

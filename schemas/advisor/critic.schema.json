    "overbuilt_parts",
    "unvalidated_assumptions",
    "what_to_cut",
    "hard_truth"
  ],
  "properties": {
    "biggest_flaw": { "type": "string" },
    "overbuilt_parts": { "type": "array", "items": { "type": "string" } },
    "unvalidated_assumptions": { "type": "array", "items": { "type": "string" } },
    "what_to_cut": { "type": "array", "items": { "type": "string" } },
    "hard_truth": { "type": "string" }
  }
}
